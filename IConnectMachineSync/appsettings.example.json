{
  "ConnectionStrings": {
    "Connection": "Server=10.0.20.20,1433;Database=JET;User Id=YOUR_USER;Password=YOUR_PASSWORD;TrustServerCertificate=True;"
  },
  "IConnect": {
    "LoginUrl": "http://jet-c.ddns.net:8080/i3sys/cgi-bin/login.cgi",
    "UserId": "YOUR_ICONNECT_USER",
    "Password": "YOUR_ICONNECT_PASSWORD",
    "MaxWaitSeconds": 90,
    "Headless": true,
    "BrowserPath": "playwright-browsers"
  },
  "Api": {
    "BaseUrl": "https://cloud.weyutech.com/jetapi/",
    "Account": "YOUR_API_ACCOUNT",
    "Password": "YOUR_API_PASSWORD",
    "ReasonNo": "99",
    "InputFormName": "iConnectMachineSync",
    "RetryCount": 3
  },
  "Sync": {
    "IntervalSeconds": 300,
    "EquipmentPrefix": "JET-",
    "SendStartupFullSync": true,
    "SendQtyAutoDc": true
  },
  "MachineSeed": {
    "Enabled": false,
    "SourceExcelPath": "outputs\\machine_exports\\machine_seed.xlsx"
  },
  "ExcelExport": {
    "Enabled": true,
    "OutputDirectory": "outputs\\machine_exports"
  },
  "Logging": {
    "ApplicationName": "IConnectMachineSync",
    "MinimumLevel": "Information",
    "File": {
      "Enabled": true,
      "RetainDays": 30,
      "FileSizeLimitMB": 50
    },
    "Seq": {
      "Enabled": false,
      "ServerUrl": "",
      "BufferRelativePath": "seq-buffer",
      "PeriodSeconds": 5
    }
  }
}
